# Required: all network traffic goes through proxy
LEDGER_PROXY_URL=http://username:password@proxy-host:port
# For Webshare rotating proxies on p.webshare.io, Ledger auto-upgrades :80 to :9999
# unless this is set:
# LEDGER_WEBSHARE_KEEP_ORIGINAL_PORT=true

# Optional explicit protocol proxies (override LEDGER_PROXY_URL)
# LEDGER_PROXY_HTTP=http://username:password@proxy-host:port
# LEDGER_PROXY_HTTPS=http://username:password@proxy-host:port
# LEDGER_PROXY_ROTATE=false
# LEDGER_PROXY_POOL=http://proxy1:port,http://proxy2:port

# Collection behavior
LEDGER_TEAM_URL=https://aimi.cornell.edu/team/
LEDGER_OUTPUT_DIR=output
LEDGER_LOOKBACK_YEARS=2
LEDGER_MEMBER_LIMIT=
LEDGER_WORKERS=2
LEDGER_MAX_RESULTS_PER_MEMBER_PER_SOURCE=300
LEDGER_MAX_GOOGLE_SCHOLAR_PAGES=2
LEDGER_SCAN_PDFS_FOR_AWARDS=true
LEDGER_PDF_SCAN_MAX_MB=30
LEDGER_PDF_SCAN_MAX_PAGES=120
LEDGER_PDF_SCAN_MAX_CANDIDATES_PER_PAPER=3
LEDGER_INCLUDE_RAW_PAYLOADS=false
LEDGER_PROBE_SOURCES_BEFORE_COLLECTION=true

# Fallback AIMI member list used if team page cannot be fetched
LEDGER_MEMBER_NAMES=Adam Braunschweig,Ala Santos,Anil Damle,B. Andrei Bernevig,Carla Gomes,Darrell Schlom,Emilia Morosan,Eun-Ah Kim,Fengqi You,Jennifer Sun,John Thickstun,Keith Brown,Kilian Weinberger,Kin Fai Mak,Leslie Schoop,Nicholas Abbott,Peter Frazier,Tess Smidt,Yoav Artzi,Zhigang Zhu

# Source toggles
LEDGER_ENABLE_DBLP=true
LEDGER_ENABLE_OPENALEX=true
LEDGER_ENABLE_SEMANTIC_SCHOLAR=true
LEDGER_ENABLE_CROSSREF=true
LEDGER_ENABLE_ARXIV=true
LEDGER_ENABLE_GOOGLE_SCHOLAR=true

# Optional API headers
# LEDGER_SEMANTIC_SCHOLAR_API_KEY=
# LEDGER_CROSSREF_MAILTO=you@example.com
# LEDGER_SERPAPI_API_KEY=your_serpapi_key

# Optional endpoint overrides (HTTP may work better on some proxy setups)
# LEDGER_OPENALEX_AUTHOR_SEARCH_API=http://api.openalex.org/authors
# LEDGER_OPENALEX_WORKS_API=http://api.openalex.org/works
# LEDGER_DBLP_AUTHOR_SEARCH_API=http://dblp.org/search/author/api
# LEDGER_DBLP_PID_XML_TEMPLATE=http://dblp.org/pid/{pid}.xml
# LEDGER_SEMANTIC_SCHOLAR_AUTHOR_SEARCH_API=http://api.semanticscholar.org/graph/v1/author/search
# LEDGER_SEMANTIC_SCHOLAR_AUTHOR_PAPERS_API_TEMPLATE=http://api.semanticscholar.org/graph/v1/author/{author_id}/papers
# LEDGER_CROSSREF_WORKS_API=http://api.crossref.org/works
# LEDGER_ARXIV_API=http://export.arxiv.org/api/query
# LEDGER_GOOGLE_SCHOLAR_SEARCH_URL=http://scholar.google.com/scholar

# Award-pattern scan in metadata and downloaded PDFs
LEDGER_AWARD_PATTERNS=DMR-2433348,DMR2433348,DMR 2433348,Award No. DMR-2433348
